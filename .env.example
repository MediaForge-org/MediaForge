# =============================================================================
# MediaForge — Environment Configuration
# =============================================================================
# 12-factor: EVERY configurable value is an environment variable. This file is
# the single source of infrastructure configuration. Runtime admin settings
# (sync intervals, thresholds) live in the database `settings` table, NOT here.
# Connector API keys/tokens are stored encrypted in the DB secret store, NOT here
# (the *_URL / *_API_KEY vars below are OPTIONAL first-run bootstrap hints only).
# =============================================================================

# --- Application -------------------------------------------------------------
APP_NAME=MediaForge
APP_ENV=production
APP_KEY=
APP_DEBUG=false
# Keep APP_URL aligned when MEDIAFORGE_PORT is overridden.
APP_URL=http://localhost:8100
APP_TIMEZONE=UTC

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# --- Security ----------------------------------------------------------------
# MediaForge uses Argon2id for password hashing (see config/hashing.php).
ARGON_MEMORY=65536
ARGON_THREADS=1
ARGON_TIME=4

# --- Host ports ---------------------------------------------------------------
# Defaults deliberately avoid SABnzbd 8080, Jellyfin 8096 and ABS 13378.
MEDIAFORGE_PORT=8100
JELLYFIN_PORT=8110
AUDIOBOOKSHELF_PORT=13380

# --- Logging (structured JSON to stdout for containers) ----------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# --- Database (PostgreSQL only — no SQLite) ----------------------------------
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=mediaforge
DB_USERNAME=mediaforge
DB_PASSWORD=change_me

# --- Sessions (in DB so HTTP survives a Redis outage) ------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# --- Cache, Queue, Redis -----------------------------------------------------
CACHE_STORE=redis
QUEUE_CONNECTION=redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# --- Horizon -----------------------------------------------------------------
HORIZON_PREFIX=mediaforge_horizon

# --- Mail (Mailpit in dev; real SMTP optional) -------------------------------
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_SCHEME=null
MAIL_FROM_ADDRESS="mediaforge@localhost"
MAIL_FROM_NAME="${APP_NAME}"

# --- Connector bootstrap hints (OPTIONAL) ------------------------------------
# The authoritative connector configuration lives in the DB (connector_instances
# + encrypted secret store). These values are only used to pre-fill the "add
# connector" flow / dev seeders. Leave blank in production.
JELLYFIN_URL=
JELLYFIN_API_KEY=
AUDIOBOOKSHELF_URL=
AUDIOBOOKSHELF_API_KEY=

# --- Frontend ----------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"

# --- Container image (set by CI at build/publish time; not read by the app) --
# MEDIAFORGE_VERSION=latest
